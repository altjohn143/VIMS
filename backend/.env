# VIMS Backend Environment Configuration
# For production deployment, set these in your hosting platform (Render, Heroku, etc.)

# Server Configuration
PORT=10000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/vims_system

# Security
JWT_SECRET=f427648afdd26d1454d31073080edba3171cd278eafb942d7a38d57d075b3ccc62dafe34de5a61c57337b913e8ef083d7a51e2ca7ea0f6c10886d321cbf3d1f0

# External Services
RESEND_API_KEY=your_resend_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PAYMONGO_SECRET_KEY=your_paymongo_secret_key_here
PAYMONGO_PUBLIC_KEY=your_paymongo_public_key_here
PAYMONGO_WEBHOOK_SECRET=your_paymongo_webhook_secret_here

# Frontend
FRONTEND_URL=https://your-frontend-domain.com

# File Encryption (auto-generated if not set)
# FILE_ENCRYPTION_KEY=your_file_encryption_key_here

# SECURITY NOTES:
# - Never commit real API keys to version control
# - Use environment variables in production deployment
# - Rotate JWT_SECRET and API keys regularly
# - Generate strong random secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"